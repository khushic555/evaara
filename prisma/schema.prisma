generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  clerkUserId  String   @unique
  email        String   @unique

  addresses    Address[]
  orders       Order[]
}

model Address {
  id          Int      @id @default(autoincrement())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  fullName    String
  phone       String
  address     String
  city        String
  state       String
  pincode     String
  country     String

  createdAt   DateTime @default(now())
}

model Order {
  id            Int      @id @default(autoincrement())

  userId        Int
  user          User     @relation(fields: [userId], references: [id])

  totalAmount   Float
  paymentId     String
  status        String

  createdAt     DateTime @default(now())
}